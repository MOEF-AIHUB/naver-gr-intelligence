# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Korean National Assembly Open API (https://open.assembly.go.kr)
ASSEMBLY_API_KEY=

# Korean Law Information Center API (https://open.law.go.kr)
LAW_API_KEY=
LAW_API_EMAIL=your@email.com

# Voyage AI (for embeddings)
VOYAGE_API_KEY=

# Cohere (optional, for rerank)
COHERE_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis (production)
REDIS_URL=redis://localhost:6379/0

# Application
LEGI_ENV=development
LEGI_LOG_LEVEL=INFO
LEGI_DATA_DIR=./data
